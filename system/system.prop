# USB GPS Switcher - System Properties
# GPS HAL will read from USB GPS module instead of built-in GNSS

# GPS mode - external USB GPS
persist.vendor.icoe.gps_mode=external
persist.vendor.icoe.gps_port=/dev/ttyUSB0
persist.vendor.icoe.gps_baud=460800

# Disable internal GPS HAL
vendor.gnss.disable.hal=true

# USB GPS ready (checked by usbgps.rc)
vendor.usb.gps.ready=0

# Debug
debug.gps.nmea.output=1
