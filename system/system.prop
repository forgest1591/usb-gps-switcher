# Magisk system.prop — GPS 相关属性
# ============================================================
# UIS7870 平台 GPS 配置
# ============================================================

# 禁用内置 GPS，使用外置 USB GPS
persist.sys.usb.gps.mode=external

# GPS 套接字配置
# 告诉 Android 位置服务使用外部数据源
ro.hardware.gps=none

# 强制使用外置 GPS 源
location.mode=device_only

# 保持屏幕唤醒时启用 GPS（省电）
location.administrative_area=
location.locality=
